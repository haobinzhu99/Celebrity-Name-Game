// Prisma schema — define your database models here.
//
// The models are yours to design (see the project spec for the game rules).
// After adding or changing a model, run:  yarn prisma:migrate
// Prisma 7 note: the connection URL lives in `prisma.config.ts`, not here.
// Docs: https://www.prisma.io/docs

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Game {
  id        Int      @id @default(autoincrement())
  roomCode  String   @unique
  answers   Answer[]
  celebrity String
}

model Answer {
  id        Int      @id @default(autoincrement())
  username  String
  celebrity String
  normalizedAnswer String 
  createdAt DateTime @default(now())
  gameId Int
  game   Game @relation(fields: [gameId], references: [id])
  
  @@unique([gameId, normalizedAnswer])
}